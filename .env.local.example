# =============================================================================
# Local development — AWS RDS + Prisma + NextAuth (no AWS RDS)
# Copy to .env.local
# =============================================================================

USE_AWS_STACK=true
USE_PRISMA_AUTH=true
NEXT_PUBLIC_USE_AWS_STACK=true
AUTO_RDS_SCHEMA=true

# AWS RDS PostgreSQL
DATABASE_URL=postgresql://prepindia_admin:PASSWORD@your-db.region.rds.amazonaws.com:5432/prepindia?sslmode=require
DIRECT_URL=postgresql://prepindia_admin:PASSWORD@your-db.region.rds.amazonaws.com:5432/prepindia?sslmode=require

# NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3002
AUTH_TRUST_HOST=true
NEXT_PUBLIC_APP_URL=http://localhost:3002

# Admin bootstrap (default login: admin@rce.ac.in / RCE_T&P)
PREPINDIA_ADMIN_EMAIL=admin@rce.ac.in
PREPINDIA_ADMIN_PASSWORD=RCE_T&P
NEXT_PUBLIC_SIGNUP_DISABLED=true

# Optional: AWS S3 proctor uploads
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=your-bucket
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Optional: Razorpay (payments disabled in app — 410)
# NEXT_PUBLIC_RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# Code execution (programming test)
# WANDBOX_API_URL=https://wandbox.org/api/compile.json
# PISTON_API_URL=https://your-piston-instance.example.com/api/v2/piston/execute

# Optional exam gateway proxy
# EXAM_GATEWAY_URL=http://127.0.0.1:4000
# EXAM_INTERNAL_API_TOKEN=dev-internal-token-change-me

# AI MCQ generation (optional)
# LOCAL_LLM_URL=http://127.0.0.1:11434
# OLLAMA_HOST=127.0.0.1
# HF_API_TOKEN=
# AI_MOCK=1
