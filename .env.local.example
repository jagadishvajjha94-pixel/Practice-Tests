NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Alternative modern Supabase key name (use either this or ANON key above)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# Set to "true" during bulk exam periods: hide public signup and enforce login-only (pre-provision users in Supabase).
# NEXT_PUBLIC_SIGNUP_DISABLED=true

NEXT_PUBLIC_RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET
POSTGRES_URL=YOUR_SUPABASE_POSTGRES_CONNECTION_STRING
