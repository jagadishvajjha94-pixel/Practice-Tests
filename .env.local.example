NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Alternative modern Supabase key name (use either this or ANON key above)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# Optional: first admin created via /auth/admin/login (defaults shown on that page)
# PREPINDIA_ADMIN_EMAIL=admin@prepindia.local
# PREPINDIA_ADMIN_PASSWORD=PrepIndia@Admin2026
# ALLOW_ADMIN_BOOTSTRAP=true
# Set to "true" during bulk exam periods: hide public signup and enforce login-only (pre-provision users in Supabase).
# NEXT_PUBLIC_SIGNUP_DISABLED=true

NEXT_PUBLIC_RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET
POSTGRES_URL=YOUR_SUPABASE_POSTGRES_CONNECTION_STRING
# Or only the database password (Settings → Database); script builds the URI from your project URL:
# SUPABASE_DB_PASSWORD=your_database_password

# Code execution (programming test)
# Local dev: uses installed compilers (python3, node, gcc, …).
# Vercel/production: uses Wandbox remote runner automatically (no config needed).
# Optional self-hosted Piston (overrides Wandbox when set):
# PISTON_API_URL=https://your-piston-instance.example.com/api/v2/piston/execute
# Optional Wandbox mirror:
# WANDBOX_API_URL=https://wandbox.org/api/compile.json
# CODING_DISABLE_WANDBOX=1
# Local only — if IDE shows spawn ENOENT:
# PYTHON_PATH=/usr/bin/python3

# --- Official exam platform (Nest "Exam" monorepo) — server-only secrets ---
# URL of api-gateway from the Exam repo (local default below).
EXAM_GATEWAY_URL=http://127.0.0.1:4000
# Must match services/exam-service INTERNAL_API_TOKEN (and requests proxied with x-internal-token).
EXAM_INTERNAL_API_TOKEN=dev-internal-token-change-me
