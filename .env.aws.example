# =============================================================================
# AWS production environment — copy to .env.production on each EC2 instance
# =============================================================================

# --- Feature flag (server + browser) ---
USE_AWS_STACK=true
USE_PRISMA_AUTH=true
NEXT_PUBLIC_USE_AWS_STACK=true

# --- Next.js ---
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://exam.yourcollege.edu.in

# --- NextAuth / Auth.js (JWT sessions — stateless across EC2 instances) ---
# Generate: openssl rand -base64 32
AUTH_SECRET=replace-with-32-byte-random-secret
AUTH_URL=https://exam.yourcollege.edu.in
AUTH_TRUST_HOST=true

# --- RDS PostgreSQL (use RDS Proxy endpoint in production) ---
DATABASE_URL=postgresql://prepindia_app:PASSWORD@prepindia-proxy.xxxxx.ap-south-1.rds.amazonaws.com:5432/prepindia?schema=public&connection_limit=10&pool_timeout=20
DIRECT_URL=postgresql://prepindia_admin:PASSWORD@prepindia.xxxxx.ap-south-1.rds.amazonaws.com:5432/prepindia?schema=public

# --- AWS S3 (proctor screenshots, exports) ---
AWS_REGION=ap-south-1
AWS_S3_BUCKET=prepindia-exam-proctoring
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# Optional: CloudFront CDN for static assets
NEXT_PUBLIC_CDN_URL=https://d1234567890.cloudfront.net

# --- Admin bootstrap (scripts/bootstrap-admin-aws.mjs) ---
PREPINDIA_ADMIN_EMAIL=admin@rce.ac.in
PREPINDIA_ADMIN_PASSWORD=RCE_T&P

# --- Rate limiting (multi-EC2: use ElastiCache Redis) ---
# REDIS_URL=redis://prepindia-redis.xxxxx.cache.amazonaws.com:6379

# --- Optional ---
NEXT_PUBLIC_SIGNUP_DISABLED=true
AUTO_RDS_SCHEMA=true
