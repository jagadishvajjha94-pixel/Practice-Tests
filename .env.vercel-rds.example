# =============================================================================
# Vercel (frontend + API) + AWS RDS PostgreSQL — trial run with students
# Copy values into Vercel → Project → Settings → Environment Variables
# =============================================================================

# --- Enable AWS / RDS mode (required) ---
USE_AWS_STACK=true
USE_PRISMA_AUTH=true
NEXT_PUBLIC_USE_AWS_STACK=true
# Auto-create tables/columns on first request (default true when USE_AWS_STACK=true)
AUTO_RDS_SCHEMA=true

# --- Public app URL (your Vercel production domain) ---
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
AUTH_URL=https://your-app.vercel.app
AUTH_TRUST_HOST=true

# --- Auth (generate: openssl rand -base64 32) ---
AUTH_SECRET=replace-with-random-32-byte-secret

# --- RDS PostgreSQL (must be reachable from the public internet for Vercel trial) ---
# Add ?sslmode=require for AWS RDS. Use connection_limit=1 on serverless.
DATABASE_URL=postgresql://prepindia_admin:PASSWORD@prepindia-db.xxxxx.ap-south-1.rds.amazonaws.com:5432/prepindia?sslmode=require&connection_limit=1
DIRECT_URL=postgresql://prepindia_admin:PASSWORD@prepindia-db.xxxxx.ap-south-1.rds.amazonaws.com:5432/prepindia?sslmode=require

# --- Trial: hide public signup; provision students in RDS ---
NEXT_PUBLIC_SIGNUP_DISABLED=true

# --- Optional: protect /api/setup/rds after first run (header: x-rds-setup-secret) ---
# RDS_SETUP_SECRET=your-random-setup-secret

# --- Admin (used only when running bootstrap script locally) ---
PREPINDIA_ADMIN_EMAIL=admin@rce.ac.in
PREPINDIA_ADMIN_PASSWORD=change-me-before-trial

# --- Optional: S3 proctor screenshots (skip for basic MCQ trial) ---
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=your-bucket
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# --- Remove / do NOT set on Vercel after migration ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
