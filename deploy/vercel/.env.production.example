# Copy each line into Vercel → Project → Settings → Environment Variables → Production
# Do not commit this file with real passwords.

USE_AWS_STACK=true
USE_PRISMA_AUTH=true
NEXT_PUBLIC_USE_AWS_STACK=true
AUTO_RDS_SCHEMA=true

DATABASE_URL=postgresql://prepindia_admin:REPLACE_PASSWORD@REPLACE_HOST.rds.amazonaws.com:5432/prepindia?sslmode=require&connection_limit=1
DIRECT_URL=postgresql://prepindia_admin:REPLACE_PASSWORD@REPLACE_HOST.rds.amazonaws.com:5432/prepindia?sslmode=require

AUTH_SECRET=REPLACE_WITH_openssl_rand_base64_32
AUTH_URL=https://REPLACE-YOUR-APP.vercel.app
AUTH_TRUST_HOST=true
NEXT_PUBLIC_APP_URL=https://REPLACE-YOUR-APP.vercel.app

PREPINDIA_ADMIN_EMAIL=admin@rce.ac.in
PREPINDIA_ADMIN_PASSWORD=REPLACE_SECURE_PASSWORD
NEXT_PUBLIC_SIGNUP_DISABLED=true

# Optional
# RDS_SETUP_SECRET=replace-after-first-setup
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=your-proctor-bucket
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
