// AWS / RDS schema — mirrors Supabase public tables + NextAuth fields.
// Run: npx prisma generate && npx prisma migrate deploy

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- NextAuth (Auth.js) ---

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// --- Core users (replaces auth.users + public.users) ---

model User {
  id                   String    @id @default(uuid()) @db.Uuid
  email                String    @unique
  passwordHash         String?   @map("password_hash")
  rollNumber           String?   @unique @map("roll_number")
  fullName             String?   @map("full_name")
  college              String?
  branch               String?
  academicYear         String?   @map("academic_year")
  cgpa                 Decimal?  @db.Decimal(3, 2)
  phone                String?
  subscriptionStatus   String?   @default("free") @map("subscription_status")
  subscriptionEndDate DateTime? @map("subscription_end_date")
  resumeText           String?   @map("resume_text")
  resumeFileName       String?   @map("resume_file_name")
  resumeStoragePath    String?   @map("resume_storage_path")
  resumeUpdatedAt      DateTime? @map("resume_updated_at")
  userRole             String?   @default("student") @map("user_role")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  accounts             Account[]
  sessions             Session[]
  adminUser            AdminUser?
  testAttempts         TestAttempt[]
  studentActiveSession StudentActiveSession?
  dashboardStats       StudentDashboardStat[]

  @@index([email])
  @@index([rollNumber])
  @@map("users")
}

model AdminUser {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  role        String   @default("admin")
  permissions Json?
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("admin_users")
}

model StudentActiveSession {
  userId       String   @id @map("user_id") @db.Uuid
  sessionId    String   @map("session_id")
  lockedAt     DateTime @default(now()) @map("locked_at")
  lastHeartbeat DateTime @default(now()) @map("last_heartbeat")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("student_active_sessions")
}

// --- Exam core ---

model TestCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  icon        String?
  order       Int?     @map("order")
  createdAt   DateTime @default(now()) @map("created_at")

  tests Test[]

  @@map("test_categories")
}

model Test {
  id                   String    @id @default(uuid()) @db.Uuid
  categoryId           String?   @map("category_id") @db.Uuid
  title                String?
  name                 String?
  description          String?
  durationMinutes      Int?      @map("duration_minutes")
  duration             Int?
  totalQuestions       Int?      @map("total_questions")
  passingScore         Int?      @map("passing_score")
  difficulty           String?
  difficultyLevel      String?   @map("difficulty_level")
  isPaid               Boolean?  @default(false) @map("is_paid")
  questionTimeLimitSec Int?      @map("question_time_limit_sec")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  category     TestCategory? @relation(fields: [categoryId], references: [id])
  testAttempts TestAttempt[]

  @@index([categoryId])
  @@map("tests")
}

model Question {
  id            String   @id @default(uuid()) @db.Uuid
  testId        String?  @map("test_id") @db.Uuid
  categoryId    String?  @map("category_id") @db.Uuid
  questionText  String   @map("question_text")
  questionType  String?  @default("MCQ") @map("question_type")
  type          String?  @default("MCQ")
  difficulty    String?  @default("medium")
  optionA       String?  @map("option_a")
  optionB       String?  @map("option_b")
  optionC       String?  @map("option_c")
  optionD       String?  @map("option_d")
  options       Json?
  correctAnswer String   @map("correct_answer")
  explanation   String?
  tags          Json?    @default("[]")
  marks         Int?     @default(1)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([testId])
  @@index([categoryId])
  @@map("questions")
}

model QuestionTag {
  id   String @id @default(uuid()) @db.Uuid
  name String
  slug String @unique

  links QuestionTagLink[]

  @@map("question_tags")
}

model QuestionTagLink {
  questionId String @map("question_id") @db.Uuid
  tagId      String @map("tag_id") @db.Uuid

  tag QuestionTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([questionId, tagId])
  @@index([tagId])
  @@index([questionId])
  @@map("question_tag_links")
}

model TestAttempt {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  testId          String?   @map("test_id")
  testTitle       String?   @map("test_title")
  startedAt       DateTime? @default(now()) @map("started_at")
  completedAt     DateTime? @map("completed_at")
  score           Decimal?  @db.Decimal(5, 2)
  percentageScore Decimal?  @map("percentage_score") @db.Decimal(5, 2)
  totalScore      Decimal?  @map("total_score") @db.Decimal(10, 2)
  answers         Json?
  timeTaken       Int?      @map("time_taken")
  status          String    @default("in_progress")
  proctorFlags    Int?      @default(0) @map("proctor_flags")
  proctorMetadata Json?     @map("proctor_metadata")
  scheduleId      String?   @map("schedule_id") @db.Uuid
  slotNumber      Int?      @map("slot_number")
  createdAt       DateTime  @default(now()) @map("created_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  test Test? @relation(fields: [testId], references: [id])

  @@index([userId, status])
  @@index([testId, status])
  @@index([userId, testId])
  @@index([completedAt])
  @@map("test_attempts")
}

model ExamSchedule {
  id                  String    @id @default(uuid()) @db.Uuid
  testId              String?   @map("test_id")
  title               String?
  description         String?
  notice              String?
  facultyExamRequestId String?  @map("faculty_exam_request_id") @db.Uuid
  status              String    @default("draft")
  startsAt            DateTime? @map("starts_at")
  endsAt              DateTime? @map("ends_at")
  targetDepartments   Json?     @default("[]") @map("target_departments")
  targetYears         Json?     @default("[]") @map("target_years")
  slotNumber          Int?      @map("slot_number")
  slotCapacity        Int?      @default(130) @map("slot_capacity")
  createdBy           String?   @map("created_by") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@index([status, startsAt])
  @@index([testId])
  @@index([facultyExamRequestId])
  @@map("exam_schedules")
}

model ExamViolation {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String?  @map("user_id") @db.Uuid
  attemptId     String?  @map("attempt_id")
  testId        String?  @map("test_id")
  violationType String   @map("violation_type")
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([attemptId])
  @@index([userId])
  @@map("exam_violations")
}

model StudentDashboardStat {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  statKey   String   @map("stat_key")
  payload   Json?
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, statKey])
  @@map("student_dashboard_stats")
}

model FacultyExamRequest {
  id                  String   @id @default(uuid()) @db.Uuid
  facultyUserId       String?  @map("faculty_user_id") @db.Uuid
  department          String?
  title               String
  description         String?
  topic               String?
  targetYears         Json?    @default("[]") @map("target_years")
  targetBranches      Json?    @default("[]") @map("target_branches")
  durationMinutes     Int?     @default(30) @map("duration_minutes")
  questionsJson       Json?    @map("questions_json")
  status              String   @default("pending")
  adminNote           String?  @map("admin_note")
  reviewedBy          String?  @map("reviewed_by") @db.Uuid
  reviewedAt          DateTime? @map("reviewed_at")
  publishedTestId     String?  @map("published_test_id")
  testType            String?  @map("test_type")
  slotKey             String?  @map("slot_key")
  syllabusTopicIds    Json?    @default("[]") @map("syllabus_topic_ids")
  questionsPerTopic   Int?     @map("questions_per_topic")
  usesSlotScheduling  Boolean  @default(false) @map("uses_slot_scheduling")
  scheduleSlotsJson   Json?    @default("[]") @map("schedule_slots_json")
  departmentGroupId   String?  @map("department_group_id") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @map("updated_at")

  @@index([status])
  @@index([facultyUserId])
  @@index([department])
  @@map("faculty_exam_requests")
}

model ExamStudentRoster {
  id         String   @id @default(uuid()) @db.Uuid
  scheduleId String?  @map("schedule_id") @db.Uuid
  rollNumber String   @map("roll_number")
  fullName   String?  @map("full_name")
  branch     String?
  year       String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([scheduleId, rollNumber])
  @@map("exam_student_roster")
}

model ExamSlotRosterEntry {
  id                   String   @id @default(uuid()) @db.Uuid
  facultyExamRequestId String?  @map("faculty_exam_request_id") @db.Uuid
  scheduleId           String?  @map("schedule_id") @db.Uuid
  slotNumber           Int?     @map("slot_number")
  rollNumber           String   @map("roll_number")
  studentName          String?  @map("student_name")
  email                String?
  password             String?
  department           String?
  year                 String?
  createdAt            DateTime @default(now()) @map("created_at")

  @@index([facultyExamRequestId, slotNumber])
  @@index([scheduleId])
  @@map("exam_slot_roster_entries")
}

model EvaloraModuleSchedule {
  id                String    @id @default(uuid()) @db.Uuid
  moduleKey         String    @map("module_key")
  title             String?
  notice            String?
  status            String    @default("scheduled")
  startsAt          DateTime  @map("starts_at")
  endsAt            DateTime? @map("ends_at")
  targetDepartments Json?     @default("[]") @map("target_departments")
  targetYears       Json?     @default("[]") @map("target_years")
  createdBy         String?   @map("created_by") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @map("updated_at")

  @@index([status, startsAt])
  @@index([moduleKey])
  @@map("evalora_module_schedules")
}

model ExamBuilderDraw {
  id                  String   @id @default(uuid()) @db.Uuid
  testType            String   @map("test_type")
  slotKey             String   @map("slot_key")
  topicIds            Json?    @default("[]") @map("topic_ids")
  questionIds         Json?    @default("[]") @map("question_ids")
  facultyExamRequestId String? @map("faculty_exam_request_id") @db.Uuid
  testId              String?  @map("test_id")
  createdBy           String?  @map("created_by") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([testType, slotKey])
  @@map("exam_builder_draws")
}

model TestQuestion {
  testId     String @map("test_id")
  questionId String @map("question_id") @db.Uuid
  sortOrder  Int?   @default(0) @map("sort_order")

  @@id([testId, questionId])
  @@index([questionId])
  @@map("test_questions")
}

model TestSection {
  id               String   @id @default(uuid()) @db.Uuid
  testId           String   @map("test_id") @db.Uuid
  name             String
  durationMinutes  Int      @map("duration_minutes")
  sortOrder        Int      @default(0) @map("sort_order")
  cutoffScore      Int?     @map("cutoff_score")
  negativeMarking  Decimal? @default(0) @map("negative_marking") @db.Decimal(4, 2)
  shuffleQuestions Boolean  @default(false) @map("shuffle_questions")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([testId, sortOrder])
  @@map("test_sections")
}

model DepartmentGroup {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  members DepartmentGroupMember[]

  @@map("department_groups")
}

model DepartmentGroupMember {
  groupId    String @map("group_id") @db.Uuid
  department String

  group DepartmentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([groupId, department])
  @@index([department])
  @@map("department_group_members")
}

model RmsetPaper {
  id                String   @id @default(uuid()) @db.Uuid
  title             String
  description       String?
  testId            String?  @map("test_id") @db.Uuid
  topicIds          Json?    @default("[]") @map("topic_ids")
  questionsPerTopic Int      @default(10) @map("questions_per_topic")
  durationMinutes   Int      @default(60) @map("duration_minutes")
  status            String   @default("draft")
  createdBy         String?  @map("created_by") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @map("updated_at")

  @@index([status])
  @@map("rmset_papers")
}

model CodingSubmission {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  questionId   String?  @map("question_id") @db.Uuid
  language     String
  sourceCode   String   @map("source_code")
  stdin        String?
  stdout       String?
  stderr       String?
  status       String   @default("pending")
  runtimeMs    Int?     @map("runtime_ms")
  memoryKb     Int?     @map("memory_kb")
  passedPublic Int?     @default(0) @map("passed_public")
  passedHidden Int?     @default(0) @map("passed_hidden")
  plagiarismHash String? @map("plagiarism_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("coding_submissions")
}

model FacultyProfile {
  userId     String   @id @map("user_id") @db.Uuid
  employeeId String?  @map("employee_id")
  department String
  fullName   String?  @map("full_name")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @map("updated_at")

  @@index([department])
  @@map("faculty_profiles")
}
