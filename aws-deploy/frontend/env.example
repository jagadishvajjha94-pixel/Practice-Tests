# PrepIndia FRONTEND — copy to .env.production on Frontend EC2
# When using split deploy, point API calls to the backend EC2.

USE_AWS_STACK=true
USE_PRISMA_AUTH=true
NEXT_PUBLIC_USE_AWS_STACK=true
NODE_ENV=production

# Public URL of THIS frontend EC2 (or domain)
NEXT_PUBLIC_APP_URL=http://YOUR_FRONTEND_EC2_IP
AUTH_URL=http://YOUR_FRONTEND_EC2_IP
AUTH_TRUST_HOST=true

# Split mode: backend EC2 API base (include /api if your nginx proxies there)
# NEXT_PUBLIC_API_URL=http://YOUR_BACKEND_EC2_IP:3001

AUTH_SECRET=replace-with-openssl-rand-base64-32
NEXT_PUBLIC_SIGNUP_DISABLED=true

# Frontend still needs DB URLs if pages use server components that hit Prisma directly
DATABASE_URL=postgresql://USER:PASS@RDS_ENDPOINT:5432/prepindia?sslmode=require&connection_limit=10
DIRECT_URL=postgresql://USER:PASS@RDS_ENDPOINT:5432/prepindia?sslmode=require
