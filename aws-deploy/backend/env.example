# PrepIndia BACKEND — copy to .env.production on Backend EC2

USE_AWS_STACK=true
USE_PRISMA_AUTH=true
NEXT_PUBLIC_USE_AWS_STACK=true
AUTO_RDS_SCHEMA=true
NODE_ENV=production

NEXT_PUBLIC_APP_URL=http://YOUR_BACKEND_EC2_IP:3001
AUTH_URL=http://YOUR_BACKEND_EC2_IP:3001
AUTH_TRUST_HOST=true
AUTH_SECRET=replace-with-openssl-rand-base64-32

DATABASE_URL=postgresql://USER:PASS@RDS_ENDPOINT:5432/prepindia?sslmode=require&connection_limit=10
DIRECT_URL=postgresql://USER:PASS@RDS_ENDPOINT:5432/prepindia?sslmode=require

PREPINDIA_ADMIN_EMAIL=admin@rce.ac.in
PREPINDIA_ADMIN_PASSWORD=change-me
NEXT_PUBLIC_SIGNUP_DISABLED=true

AWS_REGION=ap-south-1
# AWS_S3_BUCKET=your-bucket
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
